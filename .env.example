# Central stack settings. Copy this file to .env before running scripts/monitoring.sh central up.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password
GRAFANA_ROOT_URL=https://monitor.example.com
GRAFANA_COOKIE_SECURE=true
PROMETHEUS_RETENTION=30d

# Bind service ports to localhost by default. Put a TLS reverse proxy in front
# of Grafana when serving it on a public domain.
GRAFANA_HTTP_BIND=127.0.0.1
PROMETHEUS_HTTP_BIND=127.0.0.1
LOKI_HTTP_BIND=127.0.0.1

# Direct LXC install reverse proxy settings.
PUBLIC_DOMAIN=monitor.example.com
MONITORING_LISTEN_ADDRESS=127.0.0.1

# Shared credentials used by remote Alloy collectors when pushing through the
# authenticated public reverse proxy paths.
COLLECTOR_BASIC_AUTH_USER=collector
COLLECTOR_BASIC_AUTH_PASSWORD=replace-with-a-strong-collector-password

# Identity for the central server collector.
MONITOR_HOSTNAME=main-server
MONITOR_ROLE=central

# Collector-only settings. Use these before running either:
# scripts/monitoring.sh collector up
# scripts/lxc-install.sh collector
MONITORING_SERVER=monitor.example.com
# For public-domain collectors, prefer full HTTPS URLs:
# PROMETHEUS_REMOTE_WRITE_URL=https://monitor.example.com/prometheus/api/v1/write
# LOKI_WRITE_URL=https://monitor.example.com/loki/api/v1/push
# MONITOR_HOSTNAME=vm-01
# MONITOR_ROLE=vm
# Use MONITOR_ROLE=lxc for direct LXC collectors.
