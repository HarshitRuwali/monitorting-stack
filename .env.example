# Central stack settings. Copy this file to .env before running docker compose up -d.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password
GRAFANA_ROOT_URL=http://localhost:3000
PROMETHEUS_RETENTION=30d

# Identity for the central server collector.
MONITOR_HOSTNAME=main-server
MONITOR_ROLE=central

# Collector-only VM settings. Set these on each VM before running:
# docker compose -f docker-compose.collector.yml up -d
MONITORING_SERVER=192.168.1.10
# MONITOR_HOSTNAME=vm-01
# MONITOR_ROLE=vm
